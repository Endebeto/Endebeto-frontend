# Vite: exposed to the client at build time. Prefix must be VITE_.
#
# Local: omit VITE_API_URL (Vite proxies /api → backend, vite.config.ts). Or:
#   VITE_API_URL=http://localhost:3000/api/v1
#
# Deployed (Netlify and/or Vercel) + API on Render:
#   List every site origin in Render FRONTEND_URL (comma-separated).
#   Same-origin proxy (recommended for Brave / strict cookies):
#     SPA_PROXY_API_ORIGIN=https://your-api.onrender.com
#     VITE_API_URL=/api/v1
#   Legacy alias: NETLIFY_API_ORIGIN (same value as SPA_PROXY_API_ORIGIN).
#   Vercel Edge link-preview: if VITE_API_URL is /api/v1, set server-side
#     EXPERIENCE_META_API_URL=https://your-api.onrender.com/api/v1
#   Without proxy: VITE_API_URL=https://your-api.onrender.com/api/v1 (omit SPA_PROXY_API_ORIGIN).
#   With proxy: on Render set OAUTH_CALLBACK_ORIGIN=https://your-site.netlify.app (see backend/.env.example).

# VITE_API_URL=http://localhost:3000/api/v1

# Vercel edge (optional): EXPERIENCE_META_API_URL=https://your-api.onrender.com/api/v1

# Optional sitewide promo strip under the main nav (set on Vercel per environment)
# VITE_PROMO_BANNER_TEXT=Join our newsletter — new hosts welcome
# VITE_PROMO_BANNER_URL=https://example.com

# Footer social icons (optional — each icon is hidden when unset)
# VITE_SOCIAL_WEBSITE=https://endebeto.com
# VITE_SOCIAL_INSTAGRAM=https://instagram.com/yourhandle
# VITE_SOCIAL_LINKEDIN=https://linkedin.com/company/yourcompany
