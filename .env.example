# Vite: exposed to the client at build time. Prefix must be VITE_.
#
# Local development:
# VITE_API_URL=http://localhost:3000/api/v1
#
# Vercel — set per project:
#   Staging project:    https://<staging-api>.onrender.com/api/v1
#   Production project: https://<production-api>.onrender.com/api/v1

VITE_API_URL=http://localhost:3000/api/v1
